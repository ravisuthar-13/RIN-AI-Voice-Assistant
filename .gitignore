recordings/
voice_samples/
microphone_tests/

# Keep intentional sound assets
!sounds/*.wav
!sounds/*.mp3

# Test and cache folders
.pytest_cache/
.cache/

# Local databases
*.db
*.sqlite
*.sqlite3